[user]
    name = Tomek Miodek
    email = tomek.miodek@gmail.com
[core]
    editor = vim
[color]
    ui = auto
[color "branch"]
    current = green reverse
    local = green
    remote = yellow
[color "status"]
    added = green
    changed = magenta
    untracked = red
[push]
    default = upstream
[diff]
    tool = gvimdiff
[difftool]
    prompt = no
[merge]
    tool = gvimdiff
[mergetool]
    keepBackup = false
    prompt = no
[push]
    default = tracking
[alias]
    fe = fetch
    co = checkout
    st = status
    di = diff
    dt = difftool
    ds = diff --staged
    url = !git config -l | grep -E '^remote.origin.url=' | cut -d= -f2
    lg = log --graph --pretty=format:'%Cred%h%Creset %C(green)(%ci) %C(blue)%an%Creset: %s'
    ll = log --name-only
    ci = commit -a
    au = add -u .
    purr = pull --rebase
    merge = merge --no-ff
    merge-local=merge --no-ff --no-commit

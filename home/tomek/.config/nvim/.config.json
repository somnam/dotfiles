{
    "colorscheme": "default",
    "background": "dark",
    "buffer": {
        "exclude_filetype": [
          "NvimTree",
          "checkhealth",
          "codecompanion",
          "help",
          "man",
          "mason",
          "netrw",
          "nvim-pack",
          "qf",
          "tutor"
        ]
    },
    "lsp": {
        "servers": [
            "jedi_language_server",
            "lua_ls",
            "pyright",
            "quick_lint_js",
            "rust_analyzer",
            "ty",
            "vtsls"
        ],
        "log_level": "ERROR"
    },
    "treesitter" : {
        "ensure_installed": [
            "diff",
            "json",
            "lua",
            "markdown",
            "python",
            "query",
            "toml",
            "vim",
            "vimdoc",
            "yaml"
        ],
        "exclude": ["csv", "sh"]
    },
    "plugin": {
        "conform": {
            "python": ["black", "isort", "ruff_format", "ruff_fix", "ruff_organize_imports"],
            "lua": ["stylua"],
            "rust": ["rustfmt"],
            "*": ["trim_whitespace"]
        },
        "codecompanion": {
            "enable": false,
            "model": null
        },
        "copilot": {
            "enable": false,
            "workspace_folders": []
        },
        "lint": {
            "python": ["flake8", "mypy", "ruff"],
            "sql": ["sqlfluff"],
            "systemd": ["systemd-analyze"]
        },
        "mason": {
            "ensure_installed": [
                "lua-language-server",
                "stylua"
            ]
        }
    }
}
